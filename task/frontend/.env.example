# Frontend template

# Production: set to your deployed backend origin (for example https://your-backend.onrender.com)
# Local dev: leave blank to use Vite proxy in frontend/vite.config.js
VITE_API_URL=

# Clerk publishable key (safe for browser)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Optional: production defaults to execution off unless this is explicitly true.
# Local dev keeps execution on by default.
VITE_ENABLE_EXECUTE=false