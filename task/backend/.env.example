# Backend production + local template

# Network
PORT=4000
NODE_ENV=development

# Comma-separated frontend origins allowed by CORS + Socket.io
FRONTEND_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Data services
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public
REDIS_URL=redis://localhost:6379

# Clerk (required)
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# Dev-only auth bypass (keep false outside local testing)
DEV_BYPASS_AUTH=false
DEV_BYPASS_USER_ID=user_dev_local

# Code execution feature (set false on free-tier hosts without Docker daemon access)
ENABLE_EXECUTE=true
EXECUTION_TIMEOUT_MS=5000
EXECUTION_MAX_MEMORY_MB=64
EXECUTION_MAX_OUTPUT_BYTES=65536

# Logging
LOG_LEVEL=debug